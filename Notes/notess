  // 📁 order/application/OrderService.java
  package com.example.order;

  import com.example.product.ProductService;  // ✅ Import ProductService
  import com.example.product.api.ProductInfo;  // ✅ Import DTO
  import com.example.product.events.ProductEvents;  // ✅ Import Events

  @Service
  class OrderService {
      private final ProductService productService;  // ✅ Inject
      private final OrderRepository orderRepository;
      private final ApplicationEventPublisher publisher;

      // ✅ Command: Create order
      @ApplicationModulePublisher
      public Order createOrder(Long productId, int quantity) {
          // ✅ Query: Get product info
          ProductInfo product = productService.getProductInfo(productId);

          // ✅ Query: Check stock
          if (!productService.isInStock(productId, quantity)) {
              throw new RuntimeException("Not enough stock");
          }

          // Create order
          Order order = new Order();
          order.setProductId(productId);
          order.setProductName(product.name());
          order.setQuantity(quantity);
          order.setTotalPrice(product.price() * quantity);

          Order saved = orderRepository.save(order);

          // Publish event
          publisher.publishEvent(new OrderEvents.OrderCreatedEvent(
              saved.getId(),
              productId,
              quantity
          ));

          return saved;
      }

      // ✅ Event listener
      @ApplicationModuleListener
      void handleProductStockUpdated(ProductEvents.ProductStockUpdatedEvent event) {
          // React to stock update
          log.info("Product {} stock updated to {}", event.id(), event.newStock());
      }
  }


  !!This way the modular test will pass , other way it will not pass as this is the
  only intended way to pass data from one to another.
  A class with methods annotated with @ApplicationModulePublisher CAN be shared across modules!
!!The methods using methods with annotation @ApplicationModuleListener does not suppose to use
the annotation to use the method unless they are intended to be shared too.

Any class/event passed through @ApplicationModuleListener is ALLOWED to be imported in another module
and also methods related to @ApplicationModulePublisher can be imported!




