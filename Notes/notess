  A class with methods annotated with @ApplicationModulePublisher CAN be shared across modules and
  still passes the modular test!

  // 📁 product/application/ProductService.java
  package com.example.product;

  @Service
  class ProductService {
      private final ProductRepository repository;
      private final ApplicationEventPublisher publisher;

      // ✅ PUBLIC - for queries
      @ApplicationModulePublisher
      public ProductInfo getProductInfo(Long id) {
          Product product = repository.findById(id).orElseThrow();
          return new ProductInfo(product.getId(), product.getName(), product.getPrice(), product.getStock());
      }

      // ✅ PUBLIC - for queries
      @ApplicationModulePublisher
      public boolean isInStock(Long id, int quantity) {
          Product product = repository.findById(id).orElseThrow();
          return product.getStock() >= quantity;
      }

      // ✅ PUBLIC - for commands + publishes event
      @ApplicationModulePublisher
      public Product createProduct(Product product) {
          Product saved = repository.save(product);
          publisher.publishEvent(new ProductEvents.ProductCreatedEvent(
              saved.getId(),
              saved.getName(),
              saved.getPrice()
          ));
          return saved;
      }

      // ✅ PUBLIC - for commands + publishes event
      @ApplicationModulePublisher
      public void updateStock(Long id, int newStock) {
          Product product = repository.findById(id).orElseThrow();
          product.setStock(newStock);
          repository.save(product);
          publisher.publishEvent(new ProductEvents.ProductStockUpdatedEvent(id, newStock));
      }
  }

  // 📁 product/api/ProductInfo.java
  package com.example.product.api;
  public record ProductInfo(Long id, String name, Double price, Integer stock) {}


